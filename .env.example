# ─────────────────────────────────────────────────────────────────────────────
# ELI5 Environment Variables
# Copy this file to .env.local and fill in the values before running locally.
# On Vercel, add these under Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI Backend ───────────────────────────────────────────────────────────────
# Required. Any OpenAI-compatible Chat Completions API key.
OPENAI_API_KEY=your_api_key_here

# Optional. Defaults to OpenAI. Point at any compatible endpoint.
# Gemini:     https://generativelanguage.googleapis.com/v1beta/openai
# Groq:       https://api.groq.com/openai/v1
# OpenRouter: https://openrouter.ai/api/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional. Defaults to gpt-4o-mini.
OPENAI_MODEL=gpt-4o-mini

# Optional. Rate limit per IP per minute. Default: 20.
RATE_LIMIT_PER_MINUTE=20

# ── Auth (NextAuth v4) ───────────────────────────────────────────────────────
# Your deployment URL (no trailing slash).
NEXTAUTH_URL=http://localhost:3000

# Random secret for JWT signing. Generate: openssl rand -hex 32
NEXTAUTH_SECRET=your_very_long_random_secret_here

# ── Credentials provider (no database required) ───────────────────────────────
AUTH_ADMIN_EMAIL=admin@example.com

# bcrypt hash of your password. Generate:
#   node -e "require('bcryptjs').hash('YOUR_PASSWORD', 12).then(console.log)"
AUTH_ADMIN_PASSWORD_HASH=

# true = any OAuth user can sign in, false = only AUTH_ADMIN_EMAIL
AUTH_ALLOW_ALL_OAUTH=false

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth (optional) ───────────────────────────────────────────────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
